---
import { Image } from "astro:assets";
import type { ExperienceProps } from "@types";

interface Props {
  experience: ExperienceProps;
}

const { experience } = Astro.props;
const { company, logo, position, startDate, endDate, summary, href } = experience;
---
<div class="p-6 flex flex-row gap-4 rounded-xl">
  <div>
    <Image
      class="object-contain border border-accent rounded-full h-12 w-12"
      src={`${import.meta.env.BASE_URL}${logo}`}
      width="260"
      height="260"
      alt="{logo}"
    />
  </div>

  <div class="mt-2">
    <div class="mb-10">

      { href ?
        <a href={href}>
          <h3 class="mb-1.5 font-serif text-2xl font-semibold text-primary hover:underline">
            {company}
          </h3>
        </a>
      : 
          <h3 class="mb-1.5 font-serif text-2xl font-semibold text-primary">
            {company}
          </h3>
      }

      <div class="flex flex-col items-start pb-5">
        <h4 class="mb-0.5 font-serif text-2xl font-medium text-secondary">
          {position}
        </h4>
        <span class="pb-0.5 text-sm text-text">
          {startDate} — {endDate}
        </span>
      </div>
      {Array.isArray(summary) ? (
        <ul class="list-none">
          {summary.map((log) => (
            <li class="relative mb-3 pl-8 text-base text-text before:absolute before:top-1 before:left-0 before:content-[url(/check.svg)]">
              {log}
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-base text-text">{summary}</p>
      )}
    </div>
  </div>
</div>